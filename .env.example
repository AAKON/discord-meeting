REDIS_URL=

# Google API key — used for STT + Gemini (enable Speech-to-Text + Generative Language APIs)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Transcription: deepgram | google
TRANSCRIPTION_PROVIDER=google
GOOGLE_STT_LANGUAGE=bn-BD

# Deepgram (required only if TRANSCRIPTION_PROVIDER=deepgram)
DEEPGRAM_API_KEY=

# Groq (legacy, no longer used)
GROQ_API_KEY=
