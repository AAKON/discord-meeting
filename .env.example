DISCORD_TOKEN=
DISCORD_CLIENT_ID=
MONGODB_URI=
REDIS_URL=

# OpenAI — drives summarize/tasks (GPT). Not used for STT when TRANSCRIPTION_PROVIDER=groq.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=whisper-1
OPENAI_STT_LANGUAGE=bn

# Transcription provider: groq | openai | deepgram | google
# Recommended: groq — uses Whisper large-v3-turbo, free 6,000 min/day, ~10× faster than OpenAI
TRANSCRIPTION_PROVIDER=groq

# Groq (recommended STT) — free tier: 6,000 audio-minutes / day
# Sign up at https://console.groq.com → API Keys
GROQ_API_KEY=

# Optional — only needed if TRANSCRIPTION_PROVIDER is switched to them
DEEPGRAM_API_KEY=
GOOGLE_API_KEY=
GOOGLE_STT_LANGUAGE=bn-BD
